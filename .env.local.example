# Copy this file to .env.local (git-ignored) and fill in the blanks.
# For production, set the same variables in your Vercel project settings.

# --- Supabase (subscribers database) ---
# Safe to expose to the browser — used by the public subscribe form.
NEXT_PUBLIC_SUPABASE_URL=https://qfodcaoqccuvbzyvoivt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InFmb2RjYW9xY2N1dmJ6eXZvaXZ0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODI4NTMzMjgsImV4cCI6MjA5ODQyOTMyOH0.LWfG9uvbxdwKuivWs_oTCPL5UFXZ6TfoFv7Sr73qPZw
# Secret — server-only, bypasses row-level security. Get this from the Supabase
# dashboard: Project Settings > API > service_role key. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (weekly deals email) ---
# Get an API key at https://resend.com/api-keys. The from-address's domain must
# be verified in Resend before you can send from it.
RESEND_API_KEY=
RESEND_FROM_EMAIL="Sweet Crumbs Bakery <deals@yourdomain.com>"
# Inbox that receives new custom-order request notifications.
BAKERY_ORDER_NOTIFICATION_EMAIL=orders@yourdomain.com

# --- Twilio (weekly deals SMS) ---
# From the Twilio console: Account SID + Auth Token, and a Twilio phone number
# capable of sending SMS (a 10DLC or toll-free number registered for marketing use).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Cron protection ---
# Any long random string. Vercel automatically sends it as
# `Authorization: Bearer <CRON_SECRET>` when it triggers the scheduled job.
CRON_SECRET=

# --- Site URL (used for metadata + unsubscribe links) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
